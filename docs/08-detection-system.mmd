flowchart TD
    Start([Mulai]) --> PilihInput[📷 Pilih Input]
    PilihInput -->|Kamera| Kamera[Aktifkan Kamera]
    PilihInput -->|Upload| Upload[Upload Foto]

    Kamera --> Ambil[Ambil Foto]
    Upload --> PilihFile[Pilih File Gambar]
    Ambil --> Preprocess[🔄 Preprocessing]
    PilihFile --> Preprocess

    subgraph Preprocessing["Preprocessing Gambar"]
        Preprocess --> Resize[Resize ke 224x224]
        Resize --> Normalize[Normalisasi Piksel 0-1]
        Normalize --> RGB[Konversi ke RGB]
    end

    RGB --> Model[🧠 Model YOLOv8]

    subgraph Model["Deteksi Objek"]
        Model --> Feature[Extract Feature Maps]
        Feature --> Anchor[Anchor Boxes Detection]
        Anchor --> NMS[Non-Max Suppression]
        NMS --> Deteksi[Deteksi Makanan]
    end

    Deteksi --> Cocokkan[🔍 Cocokkan dengan Database]

    subgraph Matching["Matching Database"]
        Cocokkan --> AmbilDB[Ambil Data Makanan]
        AmbilDB --> Bandingkan[Bandingkan Nama & Confidence]
        Bandingkan --> Hasil[Hasil Match]
    end

    Hasil --> Tampilkan[📱 Tampilkan Hasil]

    subgraph Output["Output"]
        Tampilkan --> Gambar[Box + Label di Gambar]
        Tampilkan --> Info[Info Kalori & Gizi]
        Tampilkan --> Aksi{Aksi?}
    end

    aksi1["🔁 Ulangi"] --> PilihInput
    aksi2["💾 Simpan"] --> Simpan[Simpan ke Log Harian]
    aksi3["❌ Batal"] --> Selesai([Selesai])
    Simpan --> Selesai

    classDef start fill:#2ecc71,stroke:#27ae60,color:#fff
    classDef process fill:#3498db,stroke:#2980b9,color:#fff
    classDef decision fill:#f39c12,stroke:#e67e22,color:#fff
    classDef preprocessing fill:#1abc9c,stroke:#16a085,color:#fff
    classDef model fill:#9b59b6,stroke:#8e44ad,color:#fff
    classDef output fill:#e74c3c,stroke:#c0392b,color:#fff
    classDef success fill:#27ae60,stroke:#2ecc71,color:#fff

    class Start,PilihInput,PilihFile,Ambil,Preprocess,Resize,Normalize,RGB,Model,Feature,Anchor,NMS,Deteksi,Cocokkan,AmbilDB,Bandingkan,Hasil,Tampilkan,Gambar,Info process
    class Aksi,aksi1,aksi2,aksi3 decision
    class Simpan,Seleseai success

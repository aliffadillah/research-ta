flowchart TD
    Start([Mulai]) --> PilihMenu[Pilih Menu Prediksi]
    PilihMenu --> PilihWaktu{Pilih Jangka Waktu?}

    subgraph DataCollection["📊 Pengumpulan Data"]
        PilihWaktu --> AmbilData[Ambil Data Histori]
        AmbilData --> Nutrition[Data Nutrisi Harian]
        AmbilData --> Meals[Data Makanan]
        AmbilData --> Weight[Data Berat Badan]
        Nutrition --> Gabung[Gabungkan Dataset]
        Meals --> Gabung
        Weight --> Gabung
    end
tta
    Gabung --> Preprocessing

    subgraph Preprocess["🔄 Preprocessing"]
        Preprocessing --> Clean[Hapus Missing Value]
        Clean --> Normalize2[Normalisasi Min-Max]
        Normalize2 --> Sequence[Buat Sequence Data]
        Sequence --> Split[Train 80% / Test 20%]
    end

    Split --> ModelLSTM[🧠 Model LSTM]

    subgraph Training["Pelatihan Model"]
        ModelLSTM --> Feed[Feed Sequence ke LSTM]
        Feed --> Forward[Forward Pass]
        Forward --> Loss[Hitung Loss MSE]
        Loss --> Backprop[Backpropagation]
        Backprop --> Update[Update Bobot]
        Update --> Iterasi{Iterasi?}
        Iterasi -->|Belum Cukup| Feed
        Iterasi -->|Selesai| SaveModel[Simpan Model]
    end

    SaveModel --> Prediksi[🔮 Prediksi]

    subgraph Prediction["Prediksi"]
        Prediksi --> InputNew[Input Data Terbaru]
        InputNew --> Load[Load Model Terlatih]
        Load --> Predict[Generate Prediksi]
        Predict --> Inverse[Inverse Normalisasi]
        Inverse --> Forecast[Hasil Prediksi]
    end

    Forecast --> Visualisasi[📈 Visualisasi]

    subgraph Output["Output"]
        Visualisasi --> Grafik[Grafik Line Chart]
        Visualisasi --> Confidence[Interval Kepercayaan]
        Visualisasi --> Rekomendasi[Ringkasan Rekomendasi]
    end

    Grafik --> Selesai([Selesai])


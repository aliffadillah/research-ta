flowchart TD
    Start([Mulai]) --> BukaHalaman[User Buka Halaman Rekomendasi]
    BukaHalaman --> Analisis[Analisis Nutrisi Hari Ini]
    Analisis --> HitungKekurangan[Hitung Nutrisi yang Kurang]
    HitungKekurangan --> Urutkan[Urutkan Berdasarkan Prioritas]
    Urutkan --> AmbilDB[Ambil Data Makanan dari Database]
    AmbilDB --> FilterMakanan[Filter Makanan yang Cocok]
    FilterMakanan --> Scoring[Hitung Skor Kecocokan]
    Scoring --> Ranking[Ranking Makanan]
    Ranking --> Tampilkan[Tampilkan Kartu Rekomendasi]
    Tampilkan --> PilihAksi{Pilih Makanan?}
    PilihAksi -->|Tambah| TambahLog[Tambah ke Log Harian]
    PilihAksi -->|Lihat Detail| ModalDetail[Modal Detail Gizi]
    PilihAksi -->|Lewati| Lewati[Lewati]
    TambahLog --> Berhasil[Berhasil Ditambahkan]
    ModalDetail -.-> PilihAksi
    Lewati --> Lanjut{Lanjut ke Rekomendasi Berikutnya?}
    Lanjut -->|Ya| Tampilkan
    Lanjut -->|Tidak| Selesai([Selesai])
    Berhasil --> Selesai

    classDef start fill:#2ecc71,stroke:#27ae60,color:#fff
    classDef process fill:#3498db,stroke:#2980b9,color:#fff
    classDef decision fill:#f39c12,stroke:#e67e22,color:#fff
    classDef success fill:#27ae60,stroke:#2ecc71,color:#fff

    class Start start
    class BukaHalaman,Analisis,HitungKekurangan,Urutkan,AmbilDB,FilterMakanan,Scoring,Ranking,Tampilkan,TambahLog,ModalDetail,Lewati,Lanjut process
    class PilihAksi decision
    class Berhasil,Selesai success
